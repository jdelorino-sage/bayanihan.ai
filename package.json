{
  "name": "bayanihan-ai",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered legal technology platform for the Philippine legal ecosystem",
  "workspaces": [
    "frontend",
    "backend/api-gateway",
    "backend/search-service",
    "backend/notarial-service",
    "backend/auth-service",
    "shared"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:gateway": "npm run dev --workspace=backend/api-gateway",
    "build:frontend": "npm run build --workspace=frontend",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,css,md}\""
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
